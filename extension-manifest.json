{
  "id": "agent-loop",
  "name": "Agent Loop",
  "version": "5.1.0",
  "description": "Adds explicit loop control for goal loops, fixed-pass loops, and staged pipelines.",
  "tier": "community",
  "requires": {
    "platform": ">=2.29.0"
  },
  "provides": {
    "tools": [
      "loop_control"
    ],
    "commands": [
      "loop",
      "loop-stop"
    ],
    "hooks": [
      "session_start",
      "session_switch",
      "session_fork",
      "session_tree",
      "before_agent_start"
    ],
    "shortcuts": [
      "Ctrl+Shift+X"
    ]
  }
}
